{
    "functions": {
        "**/*.php": {
            "runtime": "vercel-php@0.7.2"
        }
    },
    "routes": [
        {
            "src": "^/$",
            "dest": "/index.php"
        },
        {
            "src": "^/pages/([^/]+\\.php)$",
            "dest": "/pages/$1"
        },
        {
            "src": "^/api/([^/]+\\.php)$",
            "dest": "/api/$1"
        },
        {
            "src": "^/auth/([^/]+\\.php)$",
            "dest": "/auth/$1"
        },
        {
            "src": "^/(.*)",
            "dest": "/$1"
        }
    ]
}